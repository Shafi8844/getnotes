# ===== GetNotes environment variables =====
# Copy to `.env` for local development. In Azure, set these in
# App Service > Settings > Environment variables.

# ----- App -----
NODE_ENV=development
PORT=8080
ALLOWED_ORIGINS=http://localhost:8080

# ----- Cosmos DB -----
# Get from: Azure Portal > Cosmos DB account > Keys
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key
COSMOS_DB_NAME=getnotes

# ----- Blob Storage -----
# Get from: Azure Portal > Storage Account > Access keys > Connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
BLOB_CONTAINER_NAME=resources

# Alternative: use Managed Identity (recommended in production).
# Leave AZURE_STORAGE_CONNECTION_STRING empty and set:
# AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount

# ----- Application Insights -----
# Get from: Azure Portal > Application Insights resource > Overview > Connection string
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# ----- Optional -----
# Used only for SAS URL generation when blob container is private.
# AZURE_STORAGE_ACCOUNT_KEY=...
