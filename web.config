<?xml version="1.0" encoding="utf-8"?>
<!--
    web.config for Azure App Service (Windows Node hosts).
    Linux App Service plans don't need this file (they use PM2 / oryx),
    but it's harmless on either OS.

    iisnode is the bridge that runs Node.js under IIS. It looks at the
    rewrite rules below to figure out:
      - serve /public assets directly from disk
      - send everything else to server.js
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <rule name="StaticContent">
          <action type="Rewrite" url="public{REQUEST_URI}" />
        </rule>
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True" />
          </conditions>
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <security>
      <requestFiltering>
        <!-- 100 MB upload limit, matches multer config -->
        <requestLimits maxAllowedContentLength="104857600" />
      </requestFiltering>
    </security>

    <iisnode
      nodeProcessCommandLine="&quot;%programfiles%\nodejs\node.exe&quot;"
      watchedFiles="web.config;*.js;routes\*.js;services\*.js"
      loggingEnabled="true"
      logDirectory="iisnode" />
  </system.webServer>
</configuration>
